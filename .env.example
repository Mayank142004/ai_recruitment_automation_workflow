# ==============================================================================
# AI Recruitment Automation Workflow — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
# All APIs below are FREE tier — no credit card required.
# ==============================================================================

# --- Groq LLM (Free tier — sign up at console.groq.com) ---
# Free: 14,400 requests/day, 30 req/minute for Llama 3 70B
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# --- Gmail API (OAuth2 — set up at console.cloud.google.com) ---
# Free: 500 emails/day
GMAIL_CREDENTIALS_JSON=path/to/credentials.json
GMAIL_SENDER_EMAIL=your_gmail@gmail.com

# --- Meta WhatsApp Cloud API (Free tier — developers.facebook.com) ---
# Free: 1,000 messages/month
WHATSAPP_TOKEN=your_meta_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_number_id

# --- Google Sheets (same OAuth as Gmail) ---
GOOGLE_SHEET_ID=your_spreadsheet_id

# --- Database ---
# Use SQLite for development (no setup needed)
DATABASE_URL=sqlite:///./recruitment.db
# Use Supabase free tier for production (500MB free):
# DATABASE_URL=postgresql://user:pass@host/db

# --- Redis for Celery (self-hosted) ---
REDIS_URL=redis://localhost:6379/0

# --- Company info for email templates ---
COMPANY_NAME=YourCompany
HR_EMAIL=hr@yourcompany.com

# --- Dashboard password ---
DASHBOARD_PASSWORD=admin123
